## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bbin/
bin/
obj/
Log/
Logs/
Secrets/

# MSBuild temporary files
*.csproj.user
*.vcxproj.user
*.sqlproj.user
*.pubxml
*.pubxml.user

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
*.VisualState.xml
TestResult.xml
nunit-agent-gc.log

# Output of MSBuild Reference GAC Utility
gacutil-gac.log

# Build Office Extension Files
__gxx_personality_v0_shared

# SQL Server files
*.mdf
*.ldf
*.ndf

# Business Intelligence projects
*.rdl.data
*.sbdf

# Visual Studio Cache Files
*.tlog
*.log
*.vsidx
*.vsp
*.vspx
*.sap
*.opendb
*.dbmdl

# Console charts
*.conchart

# Backup and restore files from NuGet
project.lock.json
project.fragment.lock.json
artifacts/

# StyleCop files
StyleCopReport.xml

# Files for Microsoft Fakes
FakesAssemblies/

# GhostDoc License file
*.GhostDoc.licx

# ReSharper is a clean tool
_ReSharper*/
*.[Re]Sharper.user
*.DotSettings.user

# JustCode
.JustCode

# TeamCity
_TeamCity*

# DB ghost
*.dbghost

# Visual Studio lanscape file
*.u2d

# Visual Studio Local Workspace info file
*.vssa

# Rider
.idea/
*.sln.iml

# VS Code
.vscode/

# Windows image directories
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Mac OS X
.DS_Store
.AppleDouble
.LSOverride

# Environments and Secrets
.env
.env.*
!*.example
secrets.json
appsettings.local.json
